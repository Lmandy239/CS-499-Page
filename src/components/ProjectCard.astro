---
import type { FeaturedProject } from '../../data/site';

interface Props {
  project: FeaturedProject;
  imageSrc?: string;
}

const { project, imageSrc: imageOverride } = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const imageSrc = imageOverride ?? (project.image ? (project.image.startsWith('/') ? project.image : `${base}${project.image}`) : undefined);

function isLinkList(value: unknown): value is readonly { text: string; href: string }[] {
  return Array.isArray(value);
}

function getHref(href: string) {
  if (href.startsWith('http') || href.startsWith('/')) {
    return href;
  }

  return `${base}${href}`;
}
---

<article class="scroll-stat panel-card group space-y-6">
  <header>
    <h3 class="text-2xl font-semibold text-slate">
      {project.title}
    </h3>
    {project.period && <p class="mt-1 font-mono text-sm text-accent">{project.period}</p>}
  </header>

  {imageSrc && (
    <div class="w-full max-w-3xl overflow-hidden rounded-xl">
      {project.link ? (
        <a href={project.link} target="_blank" rel="noopener noreferrer">
          <img
            src={imageSrc}
            alt={project.imageAlt ?? ''}
            class="w-full h-56 object-cover"
            loading="lazy"
            decoding="async"
          />
        </a>
      ) : (
        <img
          src={imageSrc}
          alt={project.imageAlt ?? ''}
          class="w-full h-56 object-cover"
          loading="lazy"
          decoding="async"
        />
      )}
    </div>
  )}

  <div class="space-y-4">
    {Array.isArray(project.summary) ? (
      <div class="space-y-4">
        {project.summary.map((paragraph) => (
          <p class="body-copy">{paragraph}</p>
        ))}
      </div>
    ) : (
      <p class="body-copy">{project.summary}</p>
    )}

    {'narrative' in project && project.narrative && (
      <div>
        <dt class="text-xs uppercase tracking-wider text-accent">
          Narrative
        </dt>

        <dd class="mt-1.5 text-slate">
          <p class="body-copy mb-1.5 text-sm">
            {project.narrative.description}
          </p>

          <a
            href={getHref(project.narrative.href)}
            class="block text-[11px] text-accent hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            {project.narrative.text}
          </a>
        </dd>
      </div>
    )}

    {project.solution && (
      <div>
        <dt class="text-xs uppercase tracking-wider text-accent">
          Version History
        </dt>

        <dd class="mt-1.5 text-slate">
          <p class="body-copy mb-1.5 text-sm">
            To download the artifact files click the link below.
          </p>

          {isLinkList(project.solution) ? (
            <div class="space-y-1">
              {project.solution.map((item) => (
                <a
                  href={getHref(item.href)}
                  class="block text-[11px] text-accent hover:underline"
                  download
                >
                  {item.text}
                </a>
              ))}
            </div>
          ) : (
            project.solution
          )}
        </dd>
      </div>
    )}

    {project.impact && (
      <div>
        <dt class="text-xs uppercase tracking-wider text-accent">
          Original Artifact
        </dt>

        <dd class="mt-1.5 text-slate">
          {isLinkList(project.impact) ? (
            <div class="space-y-1">
              {project.impact.map((item) => (
                <a
                  href={getHref(item.href)}
                  class="block text-[11px] text-accent hover:underline"
                  download
                >
                  {item.text}
                </a>
              ))}
            </div>
          ) : (
            project.impact
          )}
        </dd>
      </div>
    )}
  </div>
</article>

<style>
  .scroll-stat {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scroll-stat.reveal {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  function revealCards() {
    const cards = document.querySelectorAll('.scroll-stat');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const index = Array.from(cards).indexOf(entry.target);
          setTimeout(() => {
            entry.target.classList.add('reveal');
          }, (index % 3) * 150); 
          
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -10px 0px'
    });

    cards.forEach(card => observer.observe(card));
  }

  revealCards();
  
  document.addEventListener('astro:after-swap', revealCards);
</script>