---
import type { FeaturedProject } from '../../data/site';
import ProjectCard from './ProjectCard.astro';

interface Props {
  projects: readonly FeaturedProject[];
}

const { projects } = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

function getImageSrc(image?: string) {
  if (!image) return undefined;

  // If the image already starts with "/", use it as-is.
  // Otherwise, add the correct base path for local/GitHub Pages.
  return image.startsWith('/') ? image : `${base}${image}`;
}

function getProjectId(title: string) {
  if (title === 'Informal Code Review') return 'code-review';
  return undefined;
}
---

<section
  id="featured-projects"
  class="mb-20 scroll-mt-24 lg:mb-28 lg:scroll-mt-8"
  aria-labelledby="projects-heading"
>
  <h2 id="projects-heading" class="section-heading">Artifacts</h2>

  <div class="space-y-20">
    {projects.map((project) => (
      <div id={getProjectId(project.title)} class="scroll-mt-24 lg:scroll-mt-8">
        <ProjectCard
          project={project}
          imageSrc={getImageSrc(project.image)}
        />
      </div>
    ))}
  </div>
</section>